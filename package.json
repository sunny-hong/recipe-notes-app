{
  "name": "recipe-notes-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.13.4",
      "better-auth": "1.5.5",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.13.4",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "alchemy": "^0.90.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @recipe-notes-app/db db:push",
    "db:studio": "bun run --filter @recipe-notes-app/db db:studio",
    "db:generate": "bun run --filter @recipe-notes-app/db db:generate",
    "db:migrate": "bun run --filter @recipe-notes-app/db db:migrate",
    "deploy": "bun run --filter @recipe-notes-app/infra deploy",
    "destroy": "bun run --filter @recipe-notes-app/infra destroy",
    "test": "bun test packages/api/src/test apps/web/src/test"
  },
  "dependencies": {
    "@recipe-notes-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@recipe-notes-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
